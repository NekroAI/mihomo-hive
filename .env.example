HIVE_HOST=0.0.0.0
HIVE_PORT=9990
HIVE_DATA_DIR=/data
HIVE_CONFIG=/data/hive.config.json
MIHOMO_BIN=mihomo

# ── 账号编排（notes/account-fleet-design.md）─────────────
# AES-256-GCM 主密钥（base64 编码 32 字节）。生成：openssl rand -base64 32
# 缺失时仍能跑 dry-run；启用 apply 模式 / codex_login / codex_register 需要此密钥
HIVE_ACCOUNT_KEY=
# 私有 codex-tool 二进制路径。优先级低于 spec.codexTool.binPath（默认从 PATH 找 codex-tool）
CODEX_TOOL_BIN=codex-tool
# 关闭账号编排：HIVE_DISABLE_ACCOUNT_FLEET=true
# 切换 dry_run 模式：HIVE_ACCOUNT_FLEET_MODE=dry_run（默认）或 apply
HIVE_ACCOUNT_FLEET_MODE=dry_run
