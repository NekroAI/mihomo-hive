HIVE_HOST=0.0.0.0
HIVE_PORT=9990
HIVE_DATA_DIR=/data
HIVE_CONFIG=/data/hive.config.json
MIHOMO_BIN=mihomo

# ── 账号编排（notes/account-fleet-design.md）─────────────
# AES-256-GCM 主密钥（base64 编码 32 字节）。生成：openssl rand -base64 32
# 缺失时 scheduler 还能跑（只观察）；codex_login / codex_register jobs 需要此密钥解密 phone+password
HIVE_ACCOUNT_KEY=
# 私有 codex-tool 二进制路径。优先级低于 spec.codexTool.binPath（默认从 PATH 找 codex-tool）
CODEX_TOOL_BIN=codex-tool
# 不再有 dry_run / apply 模式开关 —— 默认 Spec 所有 enabled 标志都是 false，
# 用户在 UI 里"开启自动维护"+ 各子能力（recovery / registration）独立开关。
# 完全关闭账号编排：HIVE_DISABLE_ACCOUNT_FLEET=true
